#version 460 core

#define FLOAT_MAX 3.4028235e38f
#define PI 3.141592265359f

layout(local_size_x = 16, local_size_y = 16, local_size_z = 1) in;

layout(rg32f, binding = 0) writeonly uniform image2D imageWrite;

uniform float u_planetRadius;
uniform float u_atmosphereRadius;
uniform float u_densityFalloffR;
uniform float u_densityFalloffM;
uniform int u_opticalDepthPoints;

const vec2 planetCenter = vec2(0.f);

vec2 raySphere(vec3 center, float radius, vec3 rayOrigin, vec3 rayDir) {
  vec3 offset = rayOrigin - center;
  float a = 1.f;
  float b = 2.f * dot(offset, rayDir);
  float c = dot(offset, offset) - radius * radius;
  float discriminant = b * b - 4.f * a * c;

  if (discriminant > 0.f) {
    float s = sqrt(discriminant);
    float dstToSphereNear = max(0.f, (-b - s) / (2.f * a));
    float dstToSphereFar = (-b + s) / (2.f * a);

    if (dstToSphereFar >= 0.f)
      return vec2(dstToSphereNear, dstToSphereFar - dstToSphereNear);
  }

  return vec2(FLOAT_MAX, 0.f);
}

float densityAtPoint(vec2 densitySamplePoint, float scale) {
  float heightAboveSurface = length(densitySamplePoint - planetCenter) - u_planetRadius;
  float heightNorm = heightAboveSurface / (u_atmosphereRadius - u_planetRadius);
  float localDensity = exp(-heightNorm * scale) * (1.f - heightNorm);

  return localDensity;
}

vec2 opticalDepth(vec2 rayOrigin, vec2 rayDir, float rayLength) {
  vec2 densitySamplePoint = rayOrigin;
  float stepSize = rayLength / (u_opticalDepthPoints - 1);
  float densityR = 0.f;
  float densityM = 0.f;

  for (int i = 0; i < u_opticalDepthPoints; i++) {
    densityR = densityAtPoint(densitySamplePoint, u_densityFalloffR) * stepSize;
    densityM = densityAtPoint(densitySamplePoint, u_densityFalloffM) * stepSize;
    densitySamplePoint += rayDir * stepSize;
  }

  return vec2(densityR, densityM);
}

void main() {
  ivec2 texCoord = ivec2(gl_GlobalInvocationID.xy);
  ivec2 imgSize = imageSize(imageWrite);

  vec2 uv = vec2(texCoord) / imgSize;
  float heightNorm = uv.y;
  float angle = uv.x * PI;
  vec2 dir = vec2(sin(angle), cos(angle));
  float y = uv.x * 2.f - 1.f;
  float x = sin(acos(y));
  dir = vec2(x, y);

  vec2 inPoint = vec2(0.f, mix(u_planetRadius, u_atmosphereRadius, heightNorm));
  float dstThroughAtmosphere = raySphere(vec3(planetCenter, 0.f), u_atmosphereRadius, vec3(inPoint, 0.f), vec3(dir, 0.f)).y;
  vec2 outPoint = inPoint + dir * dstThroughAtmosphere;
  vec2 outScattering = opticalDepth(inPoint + dir * 0.01f, dir, dstThroughAtmosphere);

  imageStore(imageWrite, texCoord, vec4(outScattering, 0.f, 1.f));
}

